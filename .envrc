if [ -n "${HPCDEV_STATE_DIR:-}" ] && [ -d "$HPCDEV_STATE_DIR/flake" ]; then
  export UV_PROJECT_ENVIRONMENT="${UV_PROJECT_ENVIRONMENT:-$PWD/.venv-sif}"
  export UV_CACHE_DIR="${UV_CACHE_DIR:-$HPCDEV_STATE_DIR/uv-cache}"
else
  export UV_PROJECT_ENVIRONMENT="${UV_PROJECT_ENVIRONMENT:-$PWD/.venv}"
  export UV_CACHE_DIR="${UV_CACHE_DIR:-$PWD/.uv-cache}"
fi

if [ -n "${HPCDEV_STATE_DIR:-}" ] && [ -d "$HPCDEV_STATE_DIR/flake" ]; then
  use flake "path:$HPCDEV_STATE_DIR/flake"
else
  use flake
fi

if [ ! -d "$UV_PROJECT_ENVIRONMENT" ]; then
  if [ -n "${HPCDEV_STATE_DIR:-}" ]; then
    python_bin="${HPCDEV_PYTHON:-}"
    if [ -z "$python_bin" ]; then
      for candidate in /opt/conda/bin/python /usr/local/bin/python /usr/bin/python python3 python; do
        if command -v "$candidate" >/dev/null 2>&1; then
          python_bin="$(command -v "$candidate")"
          break
        fi
      done
    fi
    if [ -z "$python_bin" ]; then
      echo "ERROR: Python interpreter not found in the base image." >&2
      return 127
    fi
    uv venv --system-site-packages --python "$python_bin" "$UV_PROJECT_ENVIRONMENT"
  else
    uv venv "$UV_PROJECT_ENVIRONMENT"
  fi
fi

source "$UV_PROJECT_ENVIRONMENT/bin/activate"
